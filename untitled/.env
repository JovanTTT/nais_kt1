INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=mytoken
INFLUXDB_ORG=myorg
INFLUXDB_BUCKET=measurements
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=adminpass123

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Spring Boot Configuration
SPRING_APPLICATION_NAME=influxdb-app
SERVER_PORT=8080

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_INFLUXDB=DEBUG

# Database Initialization
INIT_MEASUREMENTS_COUNT=1200

# Cache Configuration
CACHE_TTL_HOURS=1
