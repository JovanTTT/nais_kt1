    {
      "name": "Delete Measurement",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/measurements/{id}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "measurements", "{id}"]
        }
